# FIREBASE_SERVICE_ACCOUNT: Required for server-side push notifications.
# Obtain this from Firebase Console -> Project Settings -> Service Accounts.
# Copy the JSON and format it as a single-line string.
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# NEXT_PUBLIC_FIREBASE_VAPID_KEY: Required for client-side push notification registration.
# Obtain this from Firebase Console -> Project Settings -> Cloud Messaging -> Web Push certificates.
NEXT_PUBLIC_FIREBASE_VAPID_KEY="YOUR_PUBLIC_VAPID_KEY"

# CRON_SECRET: Secret token to protect the /api/cron endpoint for scheduled notifications on Vercel.
CRON_SECRET="YOUR_RANDOM_SECRET_STRING"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
